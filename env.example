# vps_token_maintain.sh 环境变量示例（复制为 /etc/vps_token_maintain.env）
# 权限建议：chmod 600 /etc/vps_token_maintain.env

########################################
# 1) GitHub 仓库（必填）
########################################
# 二选一：单仓库
# REPO="owner/repo"

# 或多仓库（推荐）
REPO_LIST="owner1/repo1,owner2/repo2"

########################################
# 2) 目标 token 库路径（必填/可改）
########################################
# 默认假设你使用 CPA（cli-proxy-plus）并把 token 放这里：
AUTH_DIR="/opt/cli-proxy-plus/auths"

########################################
# 3) Release 加密方式（可选，但必须与 Actions 对齐）
########################################
# 情况 A（推荐）：Actions 设置了 AGE_RECIPIENT（age 公钥），Release 资产为 tokens.zip.age
# → VPS 侧保持默认 USE_AGE=1，并填写私钥路径：
# AGE_IDENTITY="/etc/age/xxx.key"

# 情况 B（不推荐，尤其 public repo）：Actions 未设置 AGE_RECIPIENT
# 默认会跳过上传 Release；只有设置 ALLOW_PLAINTEXT_RELEASE=true 才会上传明文 tokens.zip
# → VPS 侧必须设置 USE_AGE=0（跳过解密），并确保 Release 存在 tokens.zip：
# USE_AGE="0"

########################################
# 4) Telegram 通知（可选）
########################################
# 不填 TG_BOT_TOKEN 就会自动跳过通知
# TG_BOT_TOKEN="1234567890:AA..."
# TG_CHAT_ID="1234567890"

########################################
# 5) 运行参数（可选）
########################################
# 每个 repo 单次最多处理多少个新 release
MAX_PER_RUN="20"

# 全量扫描节流（避免风控）
SLEEP_SEC="0.2"

# 单次 wham/usage 请求超时
TIMEOUT_SEC="12"
